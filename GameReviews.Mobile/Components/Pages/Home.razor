@page "/"
@using System.Net.Http.Json
@using GameReviews.Mobile.Models
@using GameReviews.Mobile.Resources.Localization
@inject LanguageService LanguageService
@inject IJSRuntime JS
@inject HttpClient Http

<div class="page-container">
    <div class="page-header">
        <h1>@AppResources.Title</h1>
        <p>@AppResources.Subtitle</p>
    </div>

    <div style="display:flex; gap:10px; justify-content:center; margin-bottom:20px;">
        <button class="refresh-btn-custom" @onclick='() => ChangeLanguage("en-IE")'>English</button>
        <button class="refresh-btn-custom" @onclick='() => ChangeLanguage("ga-IE")'>Gaeilge</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="error-message-custom">@errorMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="success-message-custom">@successMessage</div>
    }

    <button class="refresh-btn-custom" @onclick="LoadData">@AppResources.RefreshData</button>

    <div class="tab-bar">
        <button class="tab-btn-custom @(currentView == "reviews" ? "active" : "")" @onclick='() => currentView = "reviews"'>
            @AppResources.Reviews
        </button>
        <button class="tab-btn-custom @(currentView == "games" ? "active" : "")" @onclick='() => currentView = "games"'>
            @AppResources.GamesDatabase
        </button>
    </div>

    @if (currentView == "reviews")
    {
        <div class="glass-card">
            <h2 class="mb-4 text-center">@AppResources.AddReviewHeading</h2>

            <div class="form-group-custom">
                <label>@AppResources.AuthorName:</label>
                <input class="form-input-custom" placeholder="@AppResources.AuthorNamePlaceholder" @bind="newItem.FirstName" />
            </div>

            <div class="form-group-custom">
                <label>@AppResources.GameTitle:</label>
                <input class="form-input-custom" placeholder="@AppResources.GameTitlePlaceholder" @bind="newItem.LastName" />
            </div>

            <div class="form-group-custom">
                <label>@AppResources.PlatformPlayedOn:</label>
                <input class="form-input-custom" placeholder="@AppResources.PlatformPlayedOnPlaceholder" @bind="newItem.Platform" />
            </div>

            <div class="form-group-custom">
                <label>@AppResources.YourReview:</label>
                <textarea class="form-textarea-custom" rows="4" placeholder="@AppResources.YourReviewPlaceholder" @bind="newItem.FunFact"></textarea>
            </div>

            <button class="submit-btn-custom" @onclick="AddReview">@AppResources.AddReviewButton</button>
        </div>

        <div class="section-header">
            <h2>@AppResources.RecentReviews</h2>
        </div>

        <div class="card-grid">
            @if (items.Count == 0)
            {
                <div class="review-card-custom">
                    <div class="review-text">@AppResources.NoReviews</div>
                </div>
            }
            else
            {
                @foreach (var item in items)
                {
                    <div class="review-card-custom">
                        <div class="review-title">@item.LastName</div>
                        <div class="review-author">by @item.FirstName</div>
                        <div class="review-platform">
                            @AppResources.PlayedOn: @(string.IsNullOrWhiteSpace(item.Platform) ? AppResources.NotSpecified : item.Platform)
                        </div>
                        <div class="review-text">@item.FunFact</div>
                        <div class="review-date">@item.CreatedAt.ToString("MMMM d, yyyy 'at' hh:mm tt")</div>
                    </div>
                }
            }
        </div>
    }
    else
    {
        <div class="glass-card">
            <h2 class="mb-4 text-center">@AppResources.AddGameHeading</h2>

            <div class="form-group-custom">
                <label>@AppResources.GameTitle:</label>
                <input class="form-input-custom" placeholder="@AppResources.GameTitlePlaceholder" @bind="newGame.Title" />
            </div>

            <div class="form-group-custom">
                <label>@AppResources.Genre:</label>
                <input class="form-input-custom" placeholder="@AppResources.GenrePlaceholder" @bind="newGame.Genre" />
            </div>

            <div class="form-group-custom">
                <label>@AppResources.Developer:</label>
                <input class="form-input-custom" placeholder="@AppResources.DeveloperPlaceholder" @bind="newGame.Developer" />
            </div>

            <div class="form-group-custom">
                <label>@AppResources.Platform:</label>
                <input class="form-input-custom" placeholder="@AppResources.PlatformPlaceholder" @bind="newGame.Platform" />
            </div>

            <div class="form-group-custom">
                <label>@AppResources.ReleaseYear:</label>
                <input class="form-input-custom" placeholder="@AppResources.ReleaseYearPlaceholder" @bind="newGame.ReleaseYear" />
            </div>

            <button class="submit-btn-custom" @onclick="AddGame">@AppResources.AddGameButton</button>
        </div>

        <div class="section-header">
            <h2>@AppResources.GamesDatabaseHeading</h2>
        </div>

        <div class="card-grid">
            @if (games.Count == 0)
            {
                <div class="review-card-custom">
                    <div class="review-text">@AppResources.NoGames</div>
                </div>
            }
            else
            {
                @foreach (var game in games)
                {
                    <div class="review-card-custom">
                        <div class="review-title">@game.Title</div>
                        <div class="review-author">@AppResources.Genre: @game.Genre</div>
                        <div class="review-text">
                            @AppResources.Developer: @game.Developer<br />
                            @AppResources.Platform: @game.Platform<br />
                            @AppResources.Released: @game.ReleaseYear
                        </div>
                    </div>
                }
            }
        </div>
    }
</div>

@code {
    string currentView = "reviews";

    List<Item> items = new();
    List<Game> games = new();

    Item newItem = new();
    Game newGame = new();

    string errorMessage = "";
    string successMessage = "";

    string ApiBaseUrl =>
#if ANDROID
        "http://10.0.2.2:5084";
#else
        "http://localhost:5084";
#endif

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    void ClearMessages()
    {
        errorMessage = "";
        successMessage = "";
    }

    async Task LoadData()
    {
        ClearMessages();

        for (int i = 0; i < 3; i++)
        {
            try
            {
                items = await Http.GetFromJsonAsync<List<Item>>($"{ApiBaseUrl}/api/items") ?? new();
                games = await Http.GetFromJsonAsync<List<Game>>($"{ApiBaseUrl}/api/games") ?? new();
                return;
            }
            catch
            {
                await Task.Delay(1000);
            }
        }

        errorMessage = "Could not connect to the server. Please refresh.";
    }

    async Task AddReview()
    {
        try
        {
            ClearMessages();

            var response = await Http.PostAsJsonAsync($"{ApiBaseUrl}/api/items", newItem);

            if (!response.IsSuccessStatusCode)
            {
                errorMessage = $"Failed to add review: {response.StatusCode}";
                return;
            }

            newItem = new Item();
            successMessage = "Your review has been added successfully!";
            await LoadData();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error adding review: {ex.Message}";
        }
    }

    async Task AddGame()
    {
        try
        {
            ClearMessages();

            var response = await Http.PostAsJsonAsync($"{ApiBaseUrl}/api/games", newGame);

            if (!response.IsSuccessStatusCode)
            {
                errorMessage = $"Failed to add game: {response.StatusCode}";
                return;
            }

            newGame = new Game();
            successMessage = "Game added successfully!";
            await LoadData();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error adding game: {ex.Message}";
        }
    }

    async Task ChangeLanguage(string cultureCode)
    {
        LanguageService.SetLanguage(cultureCode);
        await JS.InvokeVoidAsync("location.reload");
    }
}